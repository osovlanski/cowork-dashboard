# ─────────────────────────────────────────────
# Itay's Cowork Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit a filled-in .env to git.
# ─────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────
# Used by: Railway workers + Vercel /api/summary
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL (safe to use in dashboard frontend too)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# anon/public key — used in dashboard.html CONFIG block
SUPABASE_ANON_KEY=eyJ...

# service_role key — server-side ONLY (Railway + Vercel serverless)
SUPABASE_SERVICE_KEY=eyJ...

# ── Gmail OAuth ───────────────────────────────
# Generated by running: python workers/setup_gmail_auth.py
# Used by: Railway email-audit worker

GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...

# ── Git / GitHub ──────────────────────────────
# Used by Railway workers to push generated files back to the repo.
# The Railway service needs a deploy key or a PAT with repo write access.
# Set REPO_DIR to the checked-out repo path inside the Railway container
# (leave as "." if Railway clones to the working directory).
REPO_DIR=.
GIT_USER_NAME=itayos
GIT_USER_EMAIL=itayosov@gmail.com
GITHUB_TOKEN=ghp_...

# ── Vercel (optional — only if using Vercel CLI locally) ──────
VERCEL_TOKEN=...
