{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-block-destructive.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-secret-scan.sh" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/protect-files.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-write-secret-scan.sh" }
        ]
      }
    ]
  }
}
